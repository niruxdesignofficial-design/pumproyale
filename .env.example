# Party Royale environment configuration.
# Copy to .env and fill in. Server values are read by the SERVER only; the client
# never reads secrets. Do not commit a real .env.

# --- Server / networking ---
SERVER_PORT=2567
API_PORT=3001

# --- Database (Prisma) ---
# Dev uses SQLite for zero setup. For production, set provider = "postgresql" in
# server/prisma/schema.prisma and point this at Postgres.
DATABASE_URL=file:./dev.db

# --- Auth / sessions ---
# HMAC secret for session tokens. Change this in any real deployment.
SESSION_SECRET=dev-insecure-session-secret-change-me

# --- Solana (devnet first; never start on mainnet) ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
# Treasury keypair that signs reward transfers. Base58 secret key. SERVER ONLY.
# Leave blank to run rewards in simulation mode (no funds required).
TREASURY_SECRET_KEY=
# Reward size per match win, in lamports (default 0.01 SOL).
REWARD_LAMPORTS=10000000

# --- Client (Vite build-time, optional; sensible defaults derive from the host) ---
# VITE_SERVER_URL=ws://localhost:2567
# VITE_API_URL=http://localhost:3001
# VITE_SOLANA_RPC=https://api.devnet.solana.com
