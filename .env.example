# Party Royale environment configuration.
# Copy to .env and fill in. These values are consumed by the SERVER only, from
# Phase 6 onward. The client never reads secrets. Do not commit a real .env.

# --- Solana (devnet first; never start on mainnet) ---
# Treasury keypair used to sign reward transfers. Base58-encoded secret key.
# Server-only. Leave blank until Phase 6/7.
TREASURY_SECRET_KEY=
# RPC endpoint. Default devnet.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
# SPL token mint for rewards (optional; falls back to SOL transfer if unset).
REWARD_TOKEN_MINT=

# --- Auth / sessions (Phase 6) ---
SESSION_SECRET=

# --- Database (Phase 7) ---
# Dev uses SQLite via Prisma for zero setup; production uses Postgres.
DATABASE_URL=file:./dev.db

# --- Server / networking ---
SERVER_PORT=2567
API_PORT=3001
